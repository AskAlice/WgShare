# Copy to scripts/release.env (gitignored) and fill in. Sourced by scripts/release-local.sh.

# Signing key shared by WgShare and the ReVanced-patched SwiftKey + KDE Connect (same key so the
# CLIPBOARD_PUSH signature permission is honoured). PKCS12 or JKS.
KEYSTORE=/absolute/path/to/release.p12
KEYSTORE_PASS=changeit
KEY_ALIAS=wgshare
KEY_PASS=changeit

# GitHub Packages auth to build the ReVanced patch bundle (read:packages token).
# Passed to the revanced/ Gradle build.
# ORG_GRADLE_PROJECT_githubPackagesUsername=your-gh-username
# ORG_GRADLE_PROJECT_githubPackagesPassword=ghp_xxx

# Optional: prebuilt patch bundle / cli to skip building/downloading each run.
# PATCHES_RVP=/absolute/path/to/patches.rvp
# REVANCED_CLI_JAR=/absolute/path/to/revanced-cli-all.jar
# REVANCED_CLI_TAG=v5.0.1    # pin a specific revanced-cli release instead of latest

# Optional: reuse previously downloaded input APKs instead of fetching via apkeep.
# SWIFTKEY_XAPK=/absolute/path/to/com.touchtype.swiftkey.xapk
# KDECONNECT_APK=/absolute/path/to/org.kde.kdeconnect_tp.apk
