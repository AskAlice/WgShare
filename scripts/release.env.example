# Copy to scripts/release.env (gitignored) and fill in. Sourced by scripts/release-local.sh.

# Signing key shared by WgShare, the clipboard hook, and the LSPatch-patched SwiftKey.
# PKCS12 or JKS; converted to BKS automatically for LSPatch.
KEYSTORE=/absolute/path/to/release.p12
KEYSTORE_PASS=changeit
KEY_ALIAS=wgshare
KEY_PASS=changeit

# Optional: point at a local lspatch.jar to avoid re-downloading each run.
# LSPATCH_JAR=/absolute/path/to/lspatch.jar
# LSPATCH_TAG=v0.7    # pin a specific LSPatch release instead of latest

# Optional: reuse a previously downloaded SwiftKey artifact instead of fetching via apkeep.
# SWIFTKEY_XAPK=/absolute/path/to/com.touchtype.swiftkey.xapk
# SWIFTKEY_APK=/absolute/path/to/com.touchtype.swiftkey.apk
